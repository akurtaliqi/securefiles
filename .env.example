# MinIO credentials — copy this file to .env and fill in your values
# To simply test use the same value everywhere, but for production use strong, unique values
# Never push your .env file to version control, and never share it with anyone you don't trust
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=securefiles

